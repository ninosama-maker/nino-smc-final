<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>NINO REAL-TIME TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background: #0b0e11; color: #eaecef; overflow: hidden; height: 100vh; display: flex; flex-direction: column; font-family: 'Inter', sans-serif; }
        .ticker-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2b2f36; }
        .price-up { color: #0ecb81; }
        .price-down { color: #f6465d; }
        #signals { height: 20vh; overflow-y: auto; background: #161a1e; }
        .chart-container { flex-grow: 1; border-top: 2px solid #2b2f36; }
    </style>
</head>
<body>
    <div class="ticker-grid border-b border-gray-800">
        <div class="bg-[#161a1e] p-3 text-center">
            <div class="text-[10px] text-gray-500 font-bold uppercase">BTC/USDT</div>
            <div id="price-btcusdt" class="text-lg font-mono font-black tracking-tighter">0.00</div>
        </div>
        <div class="bg-[#161a1e] p-3 text-center">
            <div class="text-[10px] text-gray-500 font-bold uppercase">ETH/USDT</div>
            <div id="price-ethusdt" class="text-lg font-mono font-black tracking-tighter">0.00</div>
        </div>
        <div class="bg-[#161a1e] p-3 text-center">
            <div class="text-[10px] text-gray-500 font-bold uppercase">SOL/USDT</div>
            <div id="price-solusdt" class="text-lg font-mono font-black tracking-tighter">0.00</div>
        </div>
    </div>

    <div id="signals" class="p-2 space-y-2">
        <div class="text-center py-4 text-gray-600 text-[10px] font-bold uppercase tracking-[0.2em] animate-pulse">Monitoring Smart Money Displacement...</div>
    </div>

    <div class="chart-container">
        <div id="tv_chart" style="height:100%; width:100%;"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
        <script type="text/javascript">
            new TradingView.widget({
                "autosize": true,
                "symbol": "BINANCE:BTCUSDT",
                "interval": "1",
                "theme": "dark",
                "style": "1",
                "locale": "en",
                "enable_publishing": false,
                "allow_symbol_change": true,
                "container_id": "tv_chart",
                "timezone": "Asia/Kolkata"
            });
        </script>
    </div>

    <script>
        const symbols = ['btcusdt', 'ethusdt', 'solusdt'];
        let lastPrices = {};

        symbols.forEach(s => {
            // Live Ticker Stream (Mini-ticker for instant speed)
            const tickerWs = new WebSocket(`wss://stream.binance.com:9443/ws/${s}@ticker`);
            const priceEl = document.getElementById(`price-${s}`);

            tickerWs.onmessage = (e) => {
                const data = JSON.parse(e.data);
                const price = parseFloat(data.c).toFixed(s === 'btcusdt' ? 2 : 3);
                
                // Visual smooth transition
                if (lastPrices[s]) {
                    priceEl.className = price > lastPrices[s] ? 'text-lg font-mono font-black tracking-tighter price-up' : 'text-lg font-mono font-black tracking-tighter price-down';
                }
                priceEl.innerText = price;
                lastPrices[s] = price;
            };

            // SMC Signal Stream (1m Kline for displacement logic)
            const signalWs = new WebSocket(`wss://stream.binance.com:9443/ws/${s}@kline_1m`);
            signalWs.onmessage = (e) => {
                const k = JSON.parse(e.data).k;
                const displacement = Math.abs(k.c - k.o) / k.o;
                
                // 0.18% displacement filter for scalping
                if (k.x && displacement > 0.0018) {
                    const sigDiv = document.getElementById('signals');
                    if(sigDiv.innerText.includes('Monitoring')) sigDiv.innerHTML = '';
                    
                    const side = k.c > k.o ? 'BULLISH MSS' : 'BEARISH MSS';
                    const color = k.c > k.o ? 'text-green-400 border-green-900/50' : 'text-red-400 border-red-900/50';
                    
                    const card = `<div class="bg-[#1e2329] border ${color} p-3 rounded text-[11px] font-bold shadow-xl">
                        <div class="flex justify-between">
                            <span>${s.toUpperCase()}</span>
                            <span class="opacity-50">1M</span>
                        </div>
                        <div class="mt-1">${side} DETECTED @ $${parseFloat(k.c).toLocaleString()}</div>
                    </div>`;
                    sigDiv.insertAdjacentHTML('afterbegin', card);
                }
            };
        });
    </script>
</body>
</html>
